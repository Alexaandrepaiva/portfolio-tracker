{
  "name": "portfolio-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env:check": "node scripts/check-env.mjs",
    "dev": "npm run env:check && next dev",
    "build": "next build",
    "start": "npm run env:check && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/server/ingestion/fundamentus/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "ingest:fundamentus": "tsx scripts/ingest-fundamentus.ts",
    "ingest:fundamentus:auth": "tsx scripts/ingest-fundamentus-auth.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "next": "16.2.4",
    "playwright": "^1.54.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.11.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
