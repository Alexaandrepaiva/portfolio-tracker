# Database (Neon PostgreSQL via Vercel integration)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin ingestion auth
INGESTION_JOB_SECRET="replace-with-long-random-secret"

# Fundamentus collector
FUNDAMENTUS_BASE_URL="https://www.fundamentus.com.br"
FUNDAMENTUS_STORAGE_STATE_PATH=".cache/fundamentus/storage-state.json"
FUNDAMENTUS_REQUEST_TIMEOUT_MS="30000"
FUNDAMENTUS_RATE_LIMIT_MS="350"
FUNDAMENTUS_BOOTSTRAP_DAYS="30"
FUNDAMENTUS_BOOTSTRAP_DOC_LIMIT="100"
FUNDAMENTUS_ACTIONS_SUFFIX11_EXCEPTIONS="TAEE11,BRBI11,SAPR11,SANB11,KLBN11,IGTI11,ENGI11,BPAC11,ALUP11"

# Future providers (placeholders only)
MARKET_DATA_PROVIDER_API_KEY="replace-me"
DOCUMENT_INGESTION_PROVIDER_TOKEN="replace-me"
AI_PROVIDER_API_KEY="replace-me"
